# ─── Google Sheets (Service Account) ────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-cuenta@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="your-google-private-key-with-escaped-newlines"

# ─── IDs de Spreadsheets ─────────────────────────────────────────────────────
SHEET_PRODUCCION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHEET_LA_REINA_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHEET_PV_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHEET_PT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHEET_BILBAO_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHEET_VENTAS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SHEET_CONTROL_PAN_ID — descontinuado, reemplazado por Supabase Control Pan
# SHEET_CONTROL_PAN_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Control Pan — Supabase (proyecto separado) ──────────────────────────────
CONTROLPAN_SUPABASE_URL=https://your-controlpan-project.supabase.co
CONTROLPAN_SUPABASE_KEY=your-controlpan-anon-or-publishable-key

# ─── PredictHQ (Eventos cercanos a los locales) ──────────────────────────────
# Registro gratuito en https://www.predicthq.com  (free tier: 200 requests/mes)
PREDICTHQ_API_KEY=

# ─── Supabase (ConectOca) ────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
